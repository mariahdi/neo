!personal-data/*.example.md
!personal-data/*.example.json
!personal-data/skills/
personal-data/skills/*
!personal-data/skills/*.example.md

# Real local config (keep only the .example)
config/neo.config.json

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Env / secrets
.env
neo.env

# Runtime data — JSON store + uploaded photos (per instance), never committed
dashboard/data/
dashboard/data-*/

# Build artifacts (rebuildable via build-app.ps1)
build/
dist/
