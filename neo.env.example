# Neo integration credentials — TEMPLATE.
#
# Setup:
#   1. cp neo.env.example neo.env      # neo.env is gitignored; never committed
#   2. fill in your real values below (no quotes needed, but they're fine)
#   3. source neo.env                  # loads the keys into your shell session
#   4. ./check-creds.sh                # verify them
#   5. python -m neo --live            # run for real
#
# Put REAL values only in neo.env — never in this .example file (it's tracked
# by git). Base URL and repo are not secret and are pre-filled.

export NEO_JIRA_BASE_URL="https://mariahdiharris.atlassian.net"
export NEO_GITHUB_REPO="mariahdi/neo"

export NEO_JIRA_EMAIL="mariah.di.harris@gmail.com"
export NEO_JIRA_API_TOKEN=""        # id.atlassian.com -> Security -> API tokens
export NEO_ANTHROPIC_API_KEY=""     # console.anthropic.com -> API keys
export NEO_GITHUB_TOKEN=""          # GitHub PAT: Contents R/W + Pull requests R/W (or 'repo')
